# Supabase — get these from your Supabase project dashboard under Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL — used by Supabase Auth for redirect URLs after login/signup
# Local: http://localhost:3000 | Production: your Vercel URL
NEXT_PUBLIC_SITE_URL=

# Resend — email notifications (application approved/rejected, booking updates)
# Sign up at resend.com and create an API key
RESEND_API_KEY=
